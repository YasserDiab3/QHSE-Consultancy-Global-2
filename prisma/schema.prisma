datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("CLIENT")
  language      String    @default("en")
  createdAt     DateTime  @default(now()) @map("createdat")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updatedat")
  client        Client?
  activityLogs  ActivityLog[]
  reports       Report[]  @relation("ConsultantReports")

  @@index([email])
  @@map("User")
}

model Client {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  companyNameAr String?
  contactInfo   String?
  phone         String?
  address       String?
  createdAt     DateTime  @default(now()) @map("createdat")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updatedat")
  reports       Report[]

  @@index([userId])
  @@map("Client")
}

model ContactRequest {
  id         String   @id @default(uuid())
  name       String
  company    String?
  email      String
  phone      String?
  message    String
  status     String   @default("NEW")
  createdAt  DateTime @default(now()) @map("createdat")
  updatedAt  DateTime @default(now()) @updatedAt @map("updatedat")

  @@index([email])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("ContactRequest")
}

model JobOpening {
  id               String   @id @default(uuid())
  title            String
  titleAr          String?
  location         String?
  locationAr       String?
  department       String?
  departmentAr     String?
  employmentType   String
  employmentTypeAr String?
  summary          String
  summaryAr        String?
  requirements     String?
  requirementsAr   String?
  applyEmail       String?
  applyUrl         String?
  status           String   @default("OPEN")
  isPublished      Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now()) @map("createdat")
  updatedAt        DateTime @default(now()) @updatedAt @map("updatedat")

  @@index([status])
  @@index([isPublished])
  @@index([sortOrder])
  @@index([createdAt(sort: Desc)])
  @@map("JobOpening")
}

model Report {
  id            String         @id @default(uuid())
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date          DateTime
  siteName      String
  siteNameAr    String?
  category      String
  consultantId  String?
  consultant    User?          @relation("ConsultantReports", fields: [consultantId], references: [id])
  notes         String?
  notesAr       String?
  status        String         @default("OPEN")
  createdAt     DateTime       @default(now()) @map("createdat")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updatedat")
  observations  Observation[]

  @@index([clientId])
  @@index([date])
  @@map("Report")
}

model Observation {
  id            String         @id @default(uuid())
  reportId      String
  report        Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title         String
  titleAr       String?
  description   String?
  descriptionAr String?
  riskLevel     String
  status        String         @default("OPEN")
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now()) @map("createdat")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updatedat")
  images        Image[]

  @@index([reportId])
  @@map("Observation")
}

model Image {
  id             String   @id @default(uuid())
  observationId  String
  observation    Observation @relation(fields: [observationId], references: [id], onDelete: Cascade)
  type           String
  url            String
  originalName   String?
  mimeType       String?
  size           Int?
  createdAt      DateTime @default(now()) @map("createdat")

  @@index([observationId])
  @@map("Image")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  entityType  String?
  entityId    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now()) @map("createdat")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("ActivityLog")
}
